# Copy to .env.local for development. Set the same keys in Vercel → Project → Settings → Environment Variables (Production + Preview as needed).

# MUST be https:// in production. Keep this aligned with your primary Vercel domain redirect target.
# Current canonical host is www, so sitemap/canonical URLs should be https://www.salaryexit.in.
NEXT_PUBLIC_SITE_URL=https://www.salaryexit.in
NEXT_PUBLIC_CONTACT_EMAIL=hello@salaryexit.in

# Optional: comma-separated profile URLs for Organization JSON-LD (LinkedIn/X/etc.)
NEXT_PUBLIC_SITE_SAME_AS=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Plausible Analytics domain (must match domain in Plausible dashboard, e.g. salaryexit.in)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Consent
NEXT_PUBLIC_ENABLE_CONSENT_BANNER=true

# Ads (enable after approval)
NEXT_PUBLIC_ENABLE_AD_SLOTS=false

# Google AdSense — required in production before/after approval to publish valid /ads.txt
# Keep format exactly: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# AdSense display ad slot IDs (create units in AdSense → Ads → By ad unit)
# You can set only NEXT_PUBLIC_ADSENSE_SLOT_DEFAULT to reuse one unit everywhere while testing.
NEXT_PUBLIC_ADSENSE_SLOT_DEFAULT=
NEXT_PUBLIC_ADSENSE_SLOT_BELOW_HERO=
NEXT_PUBLIC_ADSENSE_SLOT_MID_CONTENT=
NEXT_PUBLIC_ADSENSE_SLOT_BELOW_RESULT=
NEXT_PUBLIC_ADSENSE_SLOT_BEFORE_FOOTER=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR_DESKTOP=

# Google Search Console (HTML tag verification content)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# IndexNow (Bing, Yandex, etc.) — key file served at https://YOUR_DOMAIN/{INDEXNOW_KEY}.txt
INDEXNOW_KEY=

# Optional: random secret to protect POST /api/indexnow (URL submission to IndexNow)
INDEXNOW_WEBHOOK_SECRET=

# ── Monetization ──────────────────────────────────────────────────────────────

# Affiliate CTAs (set to true only after replacing all "REPLACE" URLs in lib/content/affiliate-links.ts)
NEXT_PUBLIC_ENABLE_AFFILIATE_LINKS=false

# Email newsletter — Brevo (free tier: 300 emails/day, unlimited contacts)
# Get API key: app.brevo.com → Settings → API Keys → Create API Key
# Get list ID: app.brevo.com → Contacts → Lists → create a list → note the numeric ID
BREVO_API_KEY=
BREVO_LIST_ID=

# Alternative display ads — Ezoic (no traffic minimum, easier than AdSense to get into)
# Ezoic integration is DNS-level — no script tag needed here. See guide for DNS steps.
# Sign up at: ezoic.com → Add new site → Cloud integration

# Buy Me a Coffee — footer support link (just your username, not the full URL)
# Sign up at: buymeacoffee.com → your page URL is buymeacoffee.com/<username>
NEXT_PUBLIC_BUYMEACOFFEE_USERNAME=
